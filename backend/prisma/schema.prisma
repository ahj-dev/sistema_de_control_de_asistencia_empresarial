generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  EMPLEADO
  JEFE_DEPARTAMENTO
  RRHH
  ADMINISTRADOR
}

enum EstadoEmpleado {
  ACTIVO
  INACTIVO
  SUSPENDIDO
  VACACIONES
}

model Departamento {
  id          String  @id @default(uuid())
  nombre      String  @unique
  descripcion String?
  activo      Boolean @default(true)

  empleados Empleado[] @relation("EmpleadoDepartamento")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("departamentos")
}

model Empleado {
  id              String         @id @default(uuid())
  nombres         String
  apellidos       String
  cedula          String         @unique
  telefono        String?
  fechaNacimiento DateTime?      @map("fecha_nacimiento") @db.Date
  fechaIngreso    DateTime       @map("fecha_ingreso")    @db.Date
  estado          EstadoEmpleado @default(ACTIVO)

  departamentoId String       @map("departamento_id")
  departamento   Departamento @relation("EmpleadoDepartamento", fields: [departamentoId], references: [id])

  // Relación inversa con Usuario
  usuario Usuario?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([departamentoId])
  @@map("empleados")

}
model Usuario {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String  @map("password_hash")
  rol          Rol     @default(EMPLEADO)
  activo       Boolean @default(true)

  // Relación opcional con Empleado
  // Un Admin de TI puede tener usuario sin ser empleado
  empleadoId String?   @unique @map("empleado_id")
  empleado   Empleado? @relation(fields: [empleadoId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("usuarios")
}